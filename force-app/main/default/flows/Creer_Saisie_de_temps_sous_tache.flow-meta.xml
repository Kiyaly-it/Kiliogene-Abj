        <defaultConnector>
            <targetReference>Msg_d_erreur</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Exclu</defaultConnectorLabel>
        <rules>
            <name>Inclu</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>DateDebutSaisie</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>getIntervalle_de_temps_sous_tache.Date_de_debut__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DateFinSaisie</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>getIntervalle_de_temps_sous_tache.Date_de_fin__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DateDebutSaisie</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>DateFinSaisie</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>DateDebutSaisie</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>V_rification_de_l_heure</targetReference>
            </connector>
            <label>Inclu</label>
        </rules>
        <rules>
            <name>Diff_rence_de_date_d_but_fin</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>DateDebutSaisie</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>DateFinSaisie</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Date_d_but_diff_Date_de_fin</targetReference>
            </connector>
            <label>Différence de date début &amp; fin</label>
        </rules>
        <rules>
            <name>Today_1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>DateDebutSaisie</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>erreurToday_1</targetReference>
            </connector>
            <label>Today + 1</label>
        </rules>
    </decisions>
