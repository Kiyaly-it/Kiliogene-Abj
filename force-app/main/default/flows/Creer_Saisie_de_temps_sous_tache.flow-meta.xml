    <formulas>
        <name>Heuredebut</name>
        <dataType>Number</dataType>
        <expression>(
  {!Heure_de_debut}
  - DATETIMEVALUE( DATEVALUE({!Heure_de_debut}) )
) * 24</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Heurefin</name>
        <dataType>Number</dataType>
